rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Pillar 2: Validation Blueprint
    function isValidReport(data) {
      return data.keys().hasAll(['location', 'resource', 'urgency', 'people', 'status', 'createdAt', 'userId']) &&
             data.keys().size() <= 10 &&
             data.location is string && data.location.size() <= 200 &&
             data.resource in ['Food', 'Water', 'Medicine', 'Shelter'] &&
             data.urgency in ['Low', 'Medium', 'High'] &&
             data.people is number &&
             data.status is string &&
             data.createdAt is timestamp &&
             data.userId == request.auth.uid;
    }

    // reports/{reportId}
    match /reports/{reportId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      
      allow create: if isSignedIn() &&
                       isValidId(reportId) &&
                       isValidReport(incoming()) &&
                       incoming().createdAt == request.time;
      
      allow update: if isSignedIn() &&
                       isOwner(existing().userId) &&
                       isValidReport(incoming()) &&
                       incoming().createdAt == existing().createdAt &&
                       (
                         // Action: Update
                         incoming().diff(existing()).affectedKeys().hasOnly(['location', 'resource', 'urgency', 'people', 'status'])
                       );
                       
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
